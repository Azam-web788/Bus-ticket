# Server Configuration
PORT=5000

# AWS RDS PostgreSQL Database
# Option 1: Single connection string (recommended)
DATABASE_URL=postgresql://postgres:Helloworld123@busticket.us-east-1.rds.amazonaws.com:5432/bus_ticket?sslmode=require

# Option 2: Individual env vars (alternative)
DB_HOST=busticket.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=bus_ticket
DB_USER=postgres
DB_PASSWORD=
DB_SSL=true

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173



































